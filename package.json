{
  "name": "usage-glance",
  "version": "0.1.0",
  "description": "Local web dashboard showing remaining Claude and Codex usage windows",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "build": "node scripts/build-client.mjs && tsc --project tsconfig.build.json",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "service:install": "node scripts/launchd.mjs install",
    "service:start": "node scripts/launchd.mjs start",
    "service:restart": "node scripts/launchd.mjs restart",
    "service:status": "node scripts/launchd.mjs status",
    "service:uninstall": "node scripts/launchd.mjs uninstall",
    "service:verify": "node scripts/launchd.mjs verify"
  },
  "dependencies": {
    "@fastify/static": "^8.0.0",
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "esbuild": "^0.28.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
